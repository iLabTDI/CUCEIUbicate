{
  "expo": {
    "name": "CUCEIUbicate",
    "slug": "CUCEIUbicate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cucei.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "yairhdz24",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Esta aplicación necesita acceso a la biblioteca de fotos para guardar imágenes."
      }
    },
    "android": {
      "package": "com.cuceiubicate.cuceiubicate",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icono.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-video"
    ],
    "expo-build-properties":  {
      "android": {
        "compileSdkVersion": 34,
        "targetSdkVersion": 34,
        "minSdkVersion": 23,
        "kotlinVersion": "1.9.24",
        "javaToolchainVersion": 17
      }
    },
    "extra": {
      "eas": {
        "projectId": "08a561e4-8d60-47af-b4b6-f830296c28e8"
      }
    }
  }
}
