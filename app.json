{
  "expo": {
    "name": "CUCEIUbicate",
    "slug": "CUCEIUbicate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cucei.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "dark" 
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/cucei.png",
        "backgroundColor": "#000000" 
      }
    },
    "web": {
      "favicon": "./images/splash.pn"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
