{
  "expo": {
    "name": "CUCEIUbicate",
    "slug": "CUCEIUbicate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cucei.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "yairhdz24",
      "newArchEnabled": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Esta aplicación necesita acceso a la biblioteca de fotos para guardar imágenes."
      }
    },
    "android": {
      "buildProperties": {
        "gradlePlugin": "com.android.tools.build:gradle:8.0.0",
        "kotlinVersion": "1.8.0"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "newArchEnabled": true,
      "package": "com.CUCEIUbicate.CUCEIUbicate",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "networkSecurityConfig": {
              "usesCleartextTraffic": true
            }
          }
        }
      ],
      "expo-asset",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "08a561e4-8d60-47af-b4b6-f830296c28e8"
      }
    }
  }
}
